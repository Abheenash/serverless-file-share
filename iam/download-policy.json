{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadMetadataOnly",
      "Effect": "Allow",
      "Action": "dynamodb:GetItem",
      "Resource": "arn:aws:dynamodb:us-east-1:638515252275:table/sfs-metadata"
    },
    {
      "Sid": "ReadFilesOnly",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::sfs-files-638515252275/files/*"
    },
    {
      "Sid": "DecryptViaS3Only",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEquals": { "kms:ViaService": "s3.us-east-1.amazonaws.com" }
      }
    }
  ]
}
