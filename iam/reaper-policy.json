{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeleteFilesOnly",
      "Effect": "Allow",
      "Action": "s3:DeleteObject",
      "Resource": "arn:aws:s3:::sfs-files-638515252275/files/*"
    },
    {
      "Sid": "DeleteMetadataOnly",
      "Effect": "Allow",
      "Action": "dynamodb:DeleteItem",
      "Resource": "arn:aws:dynamodb:us-east-1:638515252275:table/sfs-metadata"
    },
    {
      "Sid": "SendToDLQ",
      "Effect": "Allow",
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:us-east-1:638515252275:sfs-reaper-dlq"
    }
  ]
}
